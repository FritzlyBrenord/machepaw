# =====================================================
# LUXE E-COMMERCE - SUPABASE CONFIGURATION
# =====================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local (it's gitignored for security)
# 2. Replace all placeholder values with your actual Supabase credentials
# 3. Get credentials from Supabase Dashboard → Settings → API
# =====================================================

# =====================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =====================================================

# Supabase Project URL
# Example: https://abcdefghijklmnopqrst.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (Public - safe for client-side)
# Found in: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Supabase Service Role Key (PRIVATE - Server-side only!)
# Found in: Supabase Dashboard → Settings → API → service_role secret
# ⚠️ NEVER expose this in client-side code or commit to git!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# =====================================================
# SITE CONFIGURATION
# =====================================================

# Site URL (production domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin Email
ADMIN_EMAIL=admin@luxe.com

# =====================================================
# PAYMENT GATEWAYS (Optional - Configure as needed)
# =====================================================

# Stripe Configuration (if using Stripe)
# STRIPE_PUBLIC_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Haiti Payment Providers
# MONCASH_CLIENT_ID=your-moncash-client-id
# MONCASH_CLIENT_SECRET=your-moncash-secret
# DIGICEL_API_KEY=your-digicel-api-key

# =====================================================
# EMAIL SERVICE (Optional - for transactional emails)
# =====================================================

# SMTP Configuration (example with Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# FROM_EMAIL=noreply@luxe.com
# FROM_NAME=LUXE Store

# SendGrid (Alternative)
# SENDGRID_API_KEY=SG.xxx

# =====================================================
# CLOUD STORAGE (Optional - for optimized images)
# =====================================================

# Cloudinary Configuration
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=luxe-uploads
# CLOUDINARY_API_KEY=xxx
# CLOUDINARY_API_SECRET=xxx

# =====================================================
# FEATURE FLAGS
# =====================================================

# Maintenance Mode
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Features
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_WISHLIST=true

# =====================================================
# SECURITY KEYS
# =====================================================

# JWT Secret (for custom token signing)
# JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Session Secret
# SESSION_SECRET=your-session-secret-key
